@model IEnumerable<DomeneOS.Models.Cliente>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Clientes</h1>
    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Erro"]
        </div>
    }

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success">
            @TempData["Sucesso"]
        </div>
    }
    <a asp-action="Criar" class="btn btn-primary mb-3">Novo Cliente</a>
</div>

<form method="get" class="mb-3">
    <div class="input-group">
        <input type="text"
            name="pesquisa"
            value="@ViewBag.Pesquisa"
            class="form-control"
            placeholder="Pesquise pelo Nome, CPF ou CNPJ" />
            <button type="submit" class="btn btn-primary">
                Buscar
            </button>
    </div>
</form>

<table class="table table-striped table-hover align-middle shadow-sm">
    <thead>
        <tr>
            <th>Nome</th>
            <th>Telefone</th>
            <th>Email</th>
            <th>CPF/CNPJ</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var cliente in Model)
        {
            <tr>
                <td>@cliente.Nome</td>
                <td>@cliente.Telefone</td>
                <td>@cliente.Email</td>
                <td>@cliente.CpfCnpj</td>
                <td>
                    <a asp-action="Editar" asp-route-id="@cliente.Id" class="btn btn-warning btn-sm">Editar</a> |
                    <a asp-action="Detalhes" asp-route-id="@cliente.Id" class="btn btn-info btn-sm">Detalhes</a> |
                    <form asp-action="Excluir" asp-route-id="@cliente.Id" method="post" style="display:inline;">
                        <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Tem certeza que deseja excluir esse cliente?');">
                        Excluir
                    </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>