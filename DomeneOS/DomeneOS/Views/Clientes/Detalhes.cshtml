@model DomeneOS.Models.Cliente

<h1 class="mb-4">Detalhes do Cliente</h1>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-dark text-white">Dados do Cliente</div>
</div>

<div class="card">
    <div class="card-body">
        <p><strong>Nome:</strong> @Model.Nome</p>
        <p><strong>Telefone:</strong> @Model.Telefone</p>
        <p><strong>Email:</strong> @Model.Email</p>
        <p><strong>CPF/CNPJ:</strong> @Model.CpfCnpj</p>
        <p><strong>Endereço:</strong> @(string.IsNullOrWhiteSpace(Model.Endereco) ? "Não informado" : Model.Endereco)</p>
    </div>
</div>

<div class="d-flex gap-2">
    <a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-warning px-4">
        <i class="bi bi-pencil-square"></i> Editar
    </a>
    <a asp-action="Index" class="btn btn-secondary px-4">
        <i class="bi bi-arrow-left"></i> Voltar
    </a>
</div>

