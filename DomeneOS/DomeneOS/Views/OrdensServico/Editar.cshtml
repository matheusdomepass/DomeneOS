@model DomeneOS.Models.OrdemServico

<h2 class="mb-4">
    <i class="bi bi-pencil-square"></i> Editar Ordem de Serviço
</h2>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-dark text-white">
        Dados da Ordem
    </div>

    <div class="card-body">
        <form asp-action="Editar" asp-route-id="@Model.Id" method="post">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="ClienteId" class="form-label">Cliente</label>
                <select asp-for="ClienteId" class="form-control rounded-3" asp-items="ViewBag.Clientes">
                    <option value="">Selecione um cliente</option>
                </select>
                <span asp-validation-for="ClienteId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DescricaoProblema" class="form-label">Descrição do Problema</label>
                <textarea asp-for="DescricaoProblema" class="form-control rounded-3"></textarea>
                <span asp-validation-for="DescricaoProblema" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Diagnostico" class="form-label">Diagnóstico</label>
                <textarea asp-for="Diagnostico" class="form-control rounded-3"></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="Solucao" class="form-label">Solução</label>
                <textarea asp-for="Solucao" class="form-control rounded-3"></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="Valor" class="form-label">Valor</label>
                <input asp-for="Valor" class="form-control rounded-3" type="text" />
                <span asp-validation-for="Valor" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Status" class="form-label">Status</label>
                <select asp-for="Status" class="form-control rounded-3" asp-items="Html.GetEnumSelectList<StatusOrdemServico>()"></select>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-domene-primary">
                    <i class="bi bi-floppy"></i> Salvar
                </button>

                <a asp-action="Index" class="btn btn-secondary btn-domene-secondary">
                    <i class="bi bi-arrow-left"></i> Voltar
                </a>
            </div>
        </form>
    </div>
</div>