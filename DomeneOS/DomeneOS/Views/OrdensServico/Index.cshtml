@model IEnumerable<DomeneOS.Models.OrdemServico>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Ordens de Serviço</h1>
    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Erro"]
        </div>
    }

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success">
            @TempData["Sucesso"]
        </div>
    }
    <a asp-action="Criar" class="btn btn-primary mb-3"><i class="bi bi-plus-circle"></i> Nova Ordem de Serviço</a>
</div>

<div class="mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Todas</a>
    <a asp-action="Index" asp-route-status="Aberta" class="btn btn-outline-primary btn-sm">Aberta</a>
    <a asp-action="Index" asp-route-status="EmAndamento" class="btn btn-outline-warning btn-sm">Em andamento</a>
    <a asp-action="Index" asp-route-status="Finalizada" class="btn btn-outline-success btn-sm">Finalizada</a>
    <a asp-action="Index" asp-route-status="Cancelada" class="btn btn-outline-danger btn-sm">Cancelada</a>
</div>

<table class="table table-striped table-hover align-middle shadow-sm">
    <thead>
        <tr>
            <th>Cliente</th>
            <th>Descrição</th>
            <th>Status</th>
            <th>Valor</th>
            <th>Data de Abertura</th>
            <th>Finalização</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var ordem in Model)
        {
            <tr>
                <td>@ordem.Cliente.Nome</td>
                <td>@ordem.DescricaoProblema</td>
                <td>
                    @switch (ordem.Status)
                    {
                        case StatusOrdemServico.Aberta:
                            <span class="badge bg-primary">Aberta</span>
                            break;
                        case StatusOrdemServico.EmAndamento:
                            <span class="badge bg-warning text-dark">Em andamento</span>
                            break;
                        case StatusOrdemServico.Finalizada:
                            <span class="badge bg-success">Finalizada</span>
                            break;
                        case StatusOrdemServico.Cancelada:
                            <span class="badge bg-danger">Cancelada</span>
                            break;
                    }
                </td>
                <td>@ordem.Valor.ToString("C")</td>
                <td>@ordem.DataAbertura.ToString("dd/MM/yyyy")</td>
                <td>@(ordem.DataFinalizacao.HasValue ? ordem.DataFinalizacao.Value.ToString("dd/MM/yyyy") : "-")</td>
                <td class="text-center">
                    <a asp-action="Detalhes" asp-route-id="@ordem.Id" class="btn btn-info btn-sm"><i class="bi bi-eye"></i> Detalhes</a> 
                    <a asp-action="Editar" asp-route-id="@ordem.Id" class="btn btn-warning btn-sm"><i class="bi bi-pencil-square"></i> Editar</a> 
                    <form asp-action="Excluir" asp-route-id="@ordem.Id" method="post" style="display:inline;">
                        <button type="submit"
                                class="btn btn-danger btn-sm"
                                onclick="return confirm('Tem certeza que deseja excluir esta ordem de serviço?');">
                            <i class="bi bi-trash"></i>
                            Excluir
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>